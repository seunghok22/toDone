{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "toDone",
  "version": "1.3.1",
  "identifier": "com.kimseungho.todone",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "toDone",
        "width": 800,
        "height": 750,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIwOUY2M0NEMkFCOUFEOTUKUldTVnJia3F6V09mc0tpV0I1NENJZVk1eDEzWjJ4Zmp2elZrNmJvUlRFbEFJQmluYXNUb0tJWkwK",
      "endpoints": [
        "https://github.com/seunghok22/toDone/releases/latest/download/latest.json"
      ]
    }
  }
}